# Used by docker-compose.yml. Copy to `.env` and fill in real values before `docker compose up`.

POSTGRES_USER=tel_bot
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=tel_bot

# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string
# Generate with: openssl rand -base64 48
TOKEN_ENCRYPTION_KEY=change-me-to-another-long-random-string

# Public URL of the admin panel (used for the API's CORS allow-list; the panel
# itself doesn't need this since nginx proxies /api same-origin in production)
ADMIN_PANEL_ORIGIN=http://localhost:8080

# First admin account, created automatically on first boot (idempotent seed)
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-me-strong-password

# Host port the admin panel (nginx) is published on
ADMIN_PANEL_PORT=8080
