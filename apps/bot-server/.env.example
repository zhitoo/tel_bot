PORT=3000
DATABASE_URL="postgresql://user:password@localhost:5432/tel_bot?schema=public"

# JWT signing secret for the admin panel — generate a long random string
JWT_SECRET="change-me-to-a-long-random-string"

# Key used to encrypt the bot_token (and other secrets) stored in bot_settings — generate a long random string
TOKEN_ENCRYPTION_KEY="change-me-to-another-long-random-string"

# Origin allowed to call the API (Vue admin panel dev/prod URL)
ADMIN_PANEL_ORIGIN="http://localhost:5173"

# Where uploaded category files are stored on disk
UPLOAD_DIR="./uploads"

# Used only by `npm run prisma:seed` to create the first admin account
ADMIN_DEFAULT_USERNAME="admin"
ADMIN_DEFAULT_PASSWORD="changeme123"

# NOTE: the Telegram bot token itself is NOT set here — it is entered and
# stored (encrypted) from the admin panel Settings page, per SPEC.md section 4.4.
